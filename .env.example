DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nightshift

# Upstox API
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:8000/api/auth/upstox/callback
UPSTOX_NOTIFIER_URL=http://localhost:8000/api/webhooks/upstox/token
UPSTOX_SANDBOX_TOKEN=
UPSTOX_API_BASE_URL=https://api.upstox.com

# Trading
DEFAULT_TRADING_MODE=paper
TOKEN_ENCRYPTION_KEY=

# Ingestion
WATCHLIST=NSE_EQ|INE848E01016,NSE_EQ|INE669E01016,NSE_EQ|INE002A01018
INGEST_INTERVAL=60
INGEST_TIMEFRAMES=1,5,15,60,day

# LLM (self-hosted, OpenAI-compatible)
LLM_API_URL=http://localhost:8080/v1
LLM_API_KEY=
LLM_MODEL_NAME=default

# News
FINNHUB_API_KEY=

# Agent schedules (seconds)
AGENT_NEWS_INTERVAL=300
AGENT_ORDER_FLOW_INTERVAL=60
AGENT_SESSION_INTERVAL=900
AGENT_CORRELATION_INTERVAL=1800
AGENT_RANGE_INTERVAL=3600
AGENT_BIAS_INTERVAL=14400
AGENT_LIQUIDITY_INTERVAL=3600
AGENT_STRUCTURE_INTERVAL=3600
