DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nightshift
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_API_URL=https://api-fxpractice.oanda.com
WATCHLIST=EUR_USD,GBP_USD,USD_JPY
INGEST_INTERVAL=60
INGEST_TIMEFRAMES=M5,M15,H1,H4,D

# LLM (self-hosted, OpenAI-compatible)
LLM_API_URL=http://localhost:8080/v1
LLM_API_KEY=
LLM_MODEL_NAME=default

# News
FINNHUB_API_KEY=

# Agent schedules (seconds)
AGENT_NEWS_INTERVAL=300
AGENT_ORDER_FLOW_INTERVAL=60
AGENT_SESSION_INTERVAL=900
AGENT_CORRELATION_INTERVAL=1800
AGENT_RANGE_INTERVAL=3600
AGENT_BIAS_INTERVAL=14400
AGENT_LIQUIDITY_INTERVAL=3600
AGENT_STRUCTURE_INTERVAL=3600
